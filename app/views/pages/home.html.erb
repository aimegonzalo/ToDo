<!-- Homepage container -->
<div class="min-h-screen overflow-hidden bg-white text-slate-900">

  <!-- Navbar -->
  <header class="border-b border-slate-100 bg-white/90">
    <nav class="mx-auto flex max-w-7xl items-center justify-between px-6 py-6">

      <!-- Logo -->
      <div class="flex items-center gap-3">
        <div class="flex h-10 w-10 items-center justify-center rounded-xl border-2 border-indigo-500 text-indigo-600">
          ✓
        </div>

        <h1 class="text-2xl font-bold tracking-tight text-slate-900">
          ToDo Rails
        </h1>
      </div>

      <!-- Nav actions -->
      <div class="flex items-center gap-4">
        <a href="#" class="font-medium text-slate-800 hover:text-indigo-600">
          Login
        </a>

        <a href="#" class="rounded-xl bg-indigo-600 px-5 py-3 font-medium text-white shadow-lg shadow-indigo-200 transition hover:bg-indigo-700">
          Sign up
        </a>
      </div>
    </nav>
  </header>

  <!-- Hero section -->
  <main class="relative bg-gradient-to-br from-indigo-50 via-white to-blue-50">

    <!-- Decorative background shapes -->
    <div class="absolute right-0 top-0 h-96 w-96 rounded-full bg-indigo-100/50 blur-3xl"></div>
    <div class="absolute bottom-10 left-0 h-80 w-80 rounded-full bg-violet-100/60 blur-3xl"></div>

    <section class="relative mx-auto grid min-h-[720px] max-w-7xl items-center gap-12 px-6 py-20 lg:grid-cols-2">

      <!-- Hero text -->
      <div>
        <p class="mb-6 inline-flex rounded-xl bg-indigo-100 px-4 py-2 text-sm font-semibold text-indigo-600">
          Organize your day with Rails
        </p>

        <h2 class="mb-6 max-w-xl text-5xl font-extrabold leading-tight tracking-tight text-slate-950">
          Manage your tasks
          <span class="block text-indigo-600">
            without complications.
          </span>
        </h2>

        <p class="mb-10 max-w-lg text-lg leading-8 text-slate-600">
          A simple ToDo app to create, organize and track your daily tasks.
        </p>

        <!-- Hero buttons -->
        <div class="flex flex-col gap-4 sm:flex-row">
          <a href="#" class="inline-flex items-center justify-center gap-3 rounded-xl bg-indigo-600 px-6 py-4 font-semibold text-white shadow-xl shadow-indigo-200 transition hover:-translate-y-0.5 hover:bg-indigo-700">
            <span class="text-xl">＋</span>
            Create a task
          </a>

          <a href="#" class="inline-flex items-center justify-center gap-3 rounded-xl border border-indigo-300 bg-white px-6 py-4 font-semibold text-indigo-600 transition hover:-translate-y-0.5 hover:bg-indigo-50">
            <span class="text-xl">≡</span>
            View my list
          </a>
        </div>
      </div>

      <!-- Task preview card -->
      <div class="rounded-3xl border border-slate-100 bg-white/90 p-8 shadow-2xl shadow-indigo-100 backdrop-blur">
        
        <!-- Card header -->
        <div class="mb-8 flex items-center justify-between">
          <h3 class="text-2xl font-bold text-slate-900">
            Today's tasks
          </h3>

          <span class="rounded-xl bg-indigo-100 px-4 py-2 text-sm font-semibold text-indigo-600">
            3 pending
          </span>
        </div>

        <!-- Task list -->
        <ul class="space-y-4">
          <li class="flex items-center gap-5 rounded-2xl border border-slate-200 bg-white p-5 shadow-sm">
            <span class="h-7 w-7 rounded-full border-2 border-indigo-500"></span>

            <div>
              <p class="font-semibold text-slate-900">
                Study Rails routes
              </p>
              <p class="text-sm text-slate-500">
                Practice controllers and views
              </p>
            </div>
          </li>

          <li class="flex items-center gap-5 rounded-2xl border border-slate-200 bg-white p-5 shadow-sm">
            <span class="h-7 w-7 rounded-full border-2 border-violet-500"></span>

            <div>
              <p class="font-semibold text-slate-900">
                Create task model
              </p>
              <p class="text-sm text-slate-500">
                Add title, description and status
              </p>
            </div>
          </li>

          <li class="flex items-center gap-5 rounded-2xl border border-slate-200 bg-white p-5 shadow-sm">
            <span class="h-7 w-7 rounded-full border-2 border-blue-500"></span>

            <div>
              <p class="font-semibold text-slate-900">
                Improve homepage
              </p>
              <p class="text-sm text-slate-500">
                Add Tailwind styles
              </p>
            </div>
          </li>
        </ul>
      </div>
    </section>
  </main>

  <!-- Features section -->
  <section class="bg-white px-6 py-24">
    <div class="mx-auto max-w-6xl text-center">

      <!-- Section title -->
      <p class="mb-4 font-semibold text-indigo-600">
        Keep everything in order
      </p>

      <h2 class="mb-16 text-4xl font-bold tracking-tight text-slate-900">
        Focus on what matters
      </h2>

      <!-- Feature cards -->
      <div class="grid gap-10 md:grid-cols-3">

        <!-- Feature 1 -->
        <article class="rounded-3xl p-8 transition hover:bg-indigo-50">
          <div class="mx-auto mb-6 flex h-20 w-20 items-center justify-center rounded-full bg-indigo-100 text-3xl text-indigo-600">
            ✓
          </div>

          <h3 class="mb-3 text-xl font-bold text-slate-900">
            Stay organized
          </h3>

          <p class="leading-7 text-slate-500">
            Keep all your tasks in one place and never miss anything important.
          </p>
        </article>

        <!-- Feature 2 -->
        <article class="rounded-3xl p-8 transition hover:bg-indigo-50">
          <div class="mx-auto mb-6 flex h-20 w-20 items-center justify-center rounded-full bg-violet-100 text-3xl text-violet-600">
            □
          </div>

          <h3 class="mb-3 text-xl font-bold text-slate-900">
            Be productive
          </h3>

          <p class="leading-7 text-slate-500">
            Prioritize your day and get more done with less distraction.
          </p>
        </article>

        <!-- Feature 3 -->
        <article class="rounded-3xl p-8 transition hover:bg-indigo-50">
          <div class="mx-auto mb-6 flex h-20 w-20 items-center justify-center rounded-full bg-blue-100 text-3xl text-blue-600">
            ↗
          </div>

          <h3 class="mb-3 text-xl font-bold text-slate-900">
            Track progress
          </h3>

          <p class="leading-7 text-slate-500">
            See your progress and celebrate every task completed.
          </p>
        </article>
      </div>
    </div>
  </section>

  <!-- Footer -->
  <footer class="border-t border-slate-100 bg-white px-6 py-8 text-center text-sm text-slate-400">
    © 2024 ToDo Rails. All rights reserved.
  </footer>
</div>